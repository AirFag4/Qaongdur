# Core runtime
COMPOSE_PROFILES=core,mock-video,face,vision-cpu
WEB_PORT=5173
CONTROL_API_PORT=8000
VISION_PORT=8010
FACE_API_PORT=8020
VISION_SERVICE_URL=http://vision:8010
VISION_SAMPLE_FPS=2.0
VISION_MAX_SAMPLE_FPS=10.0
MEDIA_STORAGE_TOTAL_LIMIT_BYTES=10737418240
MEDIA_STORAGE_RECORDING_SHARE_PERCENT=80
VISION_EMBEDDING_ENABLED=true
VISION_EMBEDDING_DEVICE=cpu
VISION_FACE_ENABLED=true
VISION_FACE_MIN_TRACK_SECONDS=2.0
VISION_DETECTOR_DEVICE=cpu
VISION_SEGMENT_POLL_INTERVAL_SECONDS=10
VISION_SEGMENT_MIN_AGE_SECONDS=5
VISION_SEGMENT_WORKER_COUNT=1
VISION_EXECUTION_MODE=local
VISION_QUEUE_BROKER_URL=redis://redis:6379/0
VISION_QUEUE_RESULT_BACKEND=redis://redis:6379/1
VISION_OBJECT_STORAGE_ENDPOINT=http://object-storage:9000
VISION_OBJECT_STORAGE_ACCESS_KEY=minioadmin
VISION_OBJECT_STORAGE_SECRET_KEY=minioadmin
VISION_OBJECT_STORAGE_BUCKET=qaongdur-dev
VISION_SEGMENT_UPLOAD_ENABLED=false
VISION_SEGMENT_OBJECT_PREFIX=recordings
VISION_JOB_DEFAULT_QUEUE=vision.cpu
VISION_JOB_FACE_QUEUE=vision.cpu.face
VISION_WORKER_OFFLINE_TIMEOUT_SECONDS=60
VISION_WORKER_ID=
VISION_WORKER_NAME=vision-worker-1
VISION_NODE_NAME=local-dev
VISION_NODE_SSH_ALIAS=local-dev
VISION_NODE_HOSTNAME=
VISION_NODE_DOCKER_VERSION=
VISION_NODE_NVIDIA_RUNTIME_VERSION=
VISION_WORKER_QUEUES=vision.cpu,vision.cpu.face
VISION_WORKER_CAPACITY_SLOTS=1
VISION_WORKER_HEARTBEAT_INTERVAL_SECONDS=15
VISION_WORKER_RUNTIME_DIR=./data/worker-runtime
VISION_CONTAINER_RUNTIME=runc
VISION_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
VISION_TORCH_PACKAGES=torch torchvision
VISION_NVIDIA_VISIBLE_DEVICES=
VISION_NVIDIA_DRIVER_CAPABILITIES=compute,utility
VISION_REGISTER_URL=http://vision-api:8010/api/v1/internal/analytics/workers/register
VISION_HEARTBEAT_URL=http://vision-api:8010/api/v1/internal/analytics/workers/heartbeat
VISION_JOB_STATUS_BASE_URL=http://vision-api:8010
VISION_JOB_RESULTS_BASE_URL=http://vision-api:8010
VISION_INTERNAL_API_TIMEOUT_SECONDS=120
VISION_PURGE_RETIRED_MOCK_HISTORY=false
RECORDING_PRUNE_INTERVAL_SECONDS=30
QAONGDUR_INTERNAL_SERVICE_TOKEN=qaongdur-internal-dev

# Keycloak
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.5.1
KEYCLOAK_POSTGRES_IMAGE=postgres:16-alpine
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_DB_PORT=5433
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Core data plane
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_PORT=5432
POSTGRES_DB=qaongdur
POSTGRES_USER=qaongdur
POSTGRES_PASSWORD=qaongdur
REDIS_IMAGE=redis:7-alpine
REDIS_PORT=6379

# Object storage
OBJECT_STORAGE_IMAGE=minio/minio:RELEASE.2025-09-07T16-13-09Z
OBJECT_STORAGE_CLIENT_IMAGE=minio/mc:RELEASE.2025-08-13T08-35-41Z
OBJECT_STORAGE_PORT=9000
OBJECT_STORAGE_CONSOLE_PORT=9001
OBJECT_STORAGE_ROOT_USER=minioadmin
OBJECT_STORAGE_ROOT_PASSWORD=minioadmin
OBJECT_STORAGE_BUCKET=qaongdur-dev

# Media relay
MEDIAMTX_IMAGE=bluenviron/mediamtx:1.16.3
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_HLS_PORT=8888
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_PLAYBACK_PORT=9996
MEDIAMTX_API_PORT=9997
MEDIAMTX_RECORD_SEGMENT_DURATION=60s
MEDIAMTX_RECORD_SEGMENT_DURATION_SECONDS=60

# Vector store
QDRANT_IMAGE=qdrant/qdrant
QDRANT_PORT=6333

# Mock stream publisher
MOCK_VIDEO_PATH_PREFIX=mock-video
MOCK_VIDEO_MAX_SOURCES=1
MOCK_STREAM_PATH=mock-demo
MOCK_STREAM_WIDTH=1280
MOCK_STREAM_HEIGHT=720
MOCK_STREAM_FPS=15
MOCK_STREAM_BITRATE=2500k

# Auth and approval
QAONGDUR_KEYCLOAK_STEP_UP_ACR=urn:qaongdur:loa:2
